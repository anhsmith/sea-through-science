	note = {Number: 11},
	keywords = {Abundance, Field method, Count data, Me},
	pages = {698},
	file = {Full Text PDF:C\:\\Users\\anhsm\\Zotero\\storage\\MH8FRJZW\\Skirrow et al. - 2024 - How to Count Parrots Comparing the Performance of.pdf:application/pdf},
